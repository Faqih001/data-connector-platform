package-lock.json
yarn.lock
pnpm-lock.yaml

# ========== Next.js Build Output ==========
.next/
out/
dist/
build/
.vercel

# ========== Environment Variables ==========
.env
.env.local
.env.*.local
.env.production.local
.env.development.local
.env.test.local

# ========== IDE & Editor ==========
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace
.vim
*.code-workspace

# ========== OS Files ==========
.DS_Store
Thumbs.db
._.DS_Store
*.lnk
ehthumbs.db
Desktop.ini

# ========== Debug & Logs ==========
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
lerna-debug.log*
.pnpm-debug.log*

# ========== Testing ==========
coverage/
.nyc_output/
jest-coverage/

# ========== TypeScript ==========
*.tsbuildinfo
dist/
build/

# ========== Temporary & Cache ==========
*.tmp
*.bak
*.backup
.cache/
.parcel-cache
.eslintcache

# ========== Storybook ==========
storybook-static/

# ========== Security ==========
.env
.env.production
.env.development
secrets/

# ========== macOS Specific ==========
.AppleDouble
.LSOverride
._*

# ========== Windows Specific ==========
ehthumbs.db
Desktop.ini

# ========== Misc ==========
*.orig
.#*
temp/
tmp/
